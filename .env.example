PORT=3000
NODE_ENV=production

DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres?sslmode=require
PG_POOL_MAX=10

SESSION_SECRET=replace-with-strong-secret
JWT_SECRET=replace-with-strong-jwt-secret

# Optional: if set, subscription is validated via GET this URL (expect JSON { "active": true } or { "expiresAt": "ISO date" })
# SUBSCRIPTION_API_URL=https://api.example.com/subscription/status

# Base URL used in generated QR codes (no trailing slash)
PUBLIC_BASE_URL=https://thaka-smarttable.com
CORS_ORIGINS=https://thaka-smarttable.com
