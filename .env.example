# --- Server (Passenger injects PORT on Hostinger; optional locally) ---
PORT=3000
NODE_ENV=production

# --- MySQL (Hostinger remote DB example — use values from hPanel) ---
MYSQL_HOST=auth-db1803.hstgr.io
MYSQL_PORT=3306
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_POOL_MAX=10

# --- Security (generate strong random strings; never commit real .env) ---
SESSION_SECRET=replace-with-strong-session-secret
JWT_SECRET=replace-with-strong-jwt-secret

# --- Public URL & CORS (HTTPS, no trailing slash) ---
PUBLIC_BASE_URL=https://thaka-smarttable.com
CORS_ORIGINS=https://thaka-smarttable.com,https://www.thaka-smarttable.com

# Behind Hostinger / Cloudflare proxy (recommended for correct client IP / secure cookies)
TRUST_PROXY=1

# Static root folder name relative to app root (default: public). Matches public_html content if you deploy that layout.
# PUBLIC_HTML_DIR=public

# Optional debug
# DEBUG_STARTUP=1
